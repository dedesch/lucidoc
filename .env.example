# Database
DATABASE_URL=postgresql://user:password@localhost:5432/lucidoc

# Session
SESSION_SECRET=your-secure-session-secret-here

# AWS Bedrock Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
BEDROCK_KB_ID=your-knowledge-base-id
BEDROCK_MODEL_ARN=arn:aws:bedrock:us-east-1::foundation-model/anthropic.claude-3-sonnet-20240229-v1:0

# Mock Mode (set to true to use mock responses instead of calling Bedrock)
MOCK_KB=false

# Application
NODE_ENV=development
